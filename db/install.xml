<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/educheckout_he/db" VERSION="20260723" COMMENT="EduCheckout Platform higher education pathway schema.
    Tables are prefixed mdl_local_educheckout_he_* per project naming conventions.
    The higher education structural catalogue: courses of study and their units of study.
    Run db/upgrade.php savepoints whenever this file changes."
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>

    <!--
    =========================================================================
    local_educheckout_he_coursesofstudy
    =========================================================================
    An award course a student is admitted to (a TCSI "course of study"): the
    parent structure that units of study hang off. Institutional configuration,
    not learner data — only the authoring reference (usermodified) is per-user.
    -->
    <TABLE NAME="local_educheckout_he_coursesofstudy" COMMENT="Higher education award courses (TCSI courses of study).">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10"  NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="code"         TYPE="char" LENGTH="64"  NOTNULL="true"
                                   COMMENT="Course of study code (unique institutional identifier)."/>
        <FIELD NAME="name"         TYPE="char" LENGTH="255" NOTNULL="true"
                                   COMMENT="Display name of the award course."/>
        <FIELD NAME="cricoscode"   TYPE="char" LENGTH="20"  NOTNULL="false"
                                   COMMENT="CRICOS registration code for an international course. NULL = not CRICOS-registered."/>
        <FIELD NAME="courselevel"  TYPE="char" LENGTH="32"  NOTNULL="true"
                                   COMMENT="Level of course: undergraduate, postgraduate, higherdegree, enabling, or other."/>
        <FIELD NAME="enabled"      TYPE="int"  LENGTH="2"   NOTNULL="true" DEFAULT="1"
                                   COMMENT="1 = active, 0 = retired. A per-record kill-switch."/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="usermodified" TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"
                                   COMMENT="FK → mdl_user.id who created or last changed the course of study."/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"         TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_usermodified" TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <!-- The course of study code is the institutional identifier and must be unique. -->
        <INDEX NAME="uniq_code" UNIQUE="true" FIELDS="code"/>
      </INDEXES>
    </TABLE>

    <!--
    =========================================================================
    local_educheckout_he_unitsofstudy
    =========================================================================
    A reportable teaching unit within a course of study (a TCSI "unit of
    study"), carrying the EFTSL load and field-of-education classification TCSI
    reports on. Institutional configuration; only usermodified is per-user.
    -->
    <TABLE NAME="local_educheckout_he_unitsofstudy" COMMENT="Higher education reportable teaching units (TCSI units of study).">
      <FIELDS>
        <FIELD NAME="id"              TYPE="int"    LENGTH="10"  NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseofstudyid" TYPE="int"    LENGTH="10"  NOTNULL="true"
                                      COMMENT="FK → local_educheckout_he_coursesofstudy.id (the parent award course)."/>
        <FIELD NAME="code"            TYPE="char"   LENGTH="64"  NOTNULL="true"
                                      COMMENT="Unit of study code (unique within its course of study)."/>
        <FIELD NAME="name"            TYPE="char"   LENGTH="255" NOTNULL="true"
                                      COMMENT="Display name of the unit of study."/>
        <FIELD NAME="eftsl"           TYPE="number" LENGTH="10"  NOTNULL="true" DEFAULT="0" DECIMALS="5"
                                      COMMENT="Equivalent Full-Time Student Load for the unit (e.g. 0.125)."/>
        <FIELD NAME="foecode"         TYPE="char"   LENGTH="12"  NOTNULL="false"
                                      COMMENT="Field of education code (ASCED). NULL = unspecified."/>
        <FIELD NAME="deliverymode"    TYPE="char"   LENGTH="32"  NOTNULL="true"
                                      COMMENT="Delivery mode: internal, external, or multimodal."/>
        <FIELD NAME="enabled"         TYPE="int"    LENGTH="2"   NOTNULL="true" DEFAULT="1"
                                      COMMENT="1 = active, 0 = retired. A per-record kill-switch."/>
        <FIELD NAME="timecreated"     TYPE="int"    LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified"    TYPE="int"    LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="usermodified"    TYPE="int"    LENGTH="10"  NOTNULL="true" DEFAULT="0"
                                      COMMENT="FK → mdl_user.id who created or last changed the unit of study."/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"           TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_courseofstudy"  TYPE="foreign" FIELDS="courseofstudyid" REFTABLE="local_educheckout_he_coursesofstudy" REFFIELDS="id"/>
        <KEY NAME="fk_usermodified"   TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <!-- A unit code is unique within its parent course of study. -->
        <INDEX NAME="uniq_courseofstudy_code" UNIQUE="true" FIELDS="courseofstudyid, code"/>
      </INDEXES>
    </TABLE>

    <!--
    =========================================================================
    local_educheckout_he_unitcourses
    =========================================================================
    Maps a unit of study to the Moodle course(s) that deliver it. This mapping
    is what makes the pathway claim an enrolment: owns_enrolment() returns true
    when the enrolled course maps to an enabled unit of study. The courseid
    index keeps that per-enrolment lookup a single indexed read. Mapping is
    institutional configuration; only usermodified is per-user.
    -->
    <TABLE NAME="local_educheckout_he_unitcourses" COMMENT="Maps a unit of study to the Moodle course(s) that deliver it.">
      <FIELDS>
        <FIELD NAME="id"            TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="unitofstudyid" TYPE="int" LENGTH="10" NOTNULL="true"
                                    COMMENT="FK → local_educheckout_he_unitsofstudy.id."/>
        <FIELD NAME="courseid"      TYPE="int" LENGTH="10" NOTNULL="true"
                                    COMMENT="FK → mdl_course.id (the Moodle course that delivers the unit)."/>
        <FIELD NAME="timecreated"   TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified"  TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="usermodified"  TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                                    COMMENT="FK → mdl_user.id who created or last changed the mapping."/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"          TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_unitofstudy"   TYPE="foreign" FIELDS="unitofstudyid" REFTABLE="local_educheckout_he_unitsofstudy" REFFIELDS="id"/>
        <KEY NAME="fk_courseid"      TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="fk_usermodified"  TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <!-- One mapping per unit/course pair. -->
        <INDEX NAME="uniq_unit_course" UNIQUE="true" FIELDS="unitofstudyid, courseid"/>
        <!-- owns_enrolment() looks up by Moodle course id on every new enrolment. -->
        <INDEX NAME="idx_courseid" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>

    <!--
    =========================================================================
    local_educheckout_he_students
    =========================================================================
    A learner's higher education elements TCSI reports on but Moodle does not
    hold: citizenship/residency status, USI and CHESSN, disability, and highest
    prior educational attainment. One row per learner (unique userid). This is
    the learner's personal data — and the disability element is special-category
    under the Australian Privacy Principles — so the whole subsystem is
    capability-gated, off by default, and fully covered by the Privacy API. The
    coded fields store internal codes mapped to TCSI code sets at export time.
    -->
    <TABLE NAME="local_educheckout_he_students" COMMENT="Per-learner higher education elements (TCSI student data). Sensitive personal data.">
      <FIELDS>
        <FIELD NAME="id"             TYPE="int"  LENGTH="10"  NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid"         TYPE="int"  LENGTH="10"  NOTNULL="true"
                                     COMMENT="FK → mdl_user.id the higher education elements are about."/>
        <FIELD NAME="citizenship"    TYPE="char" LENGTH="32"  NOTNULL="true" DEFAULT="notstated"
                                     COMMENT="Citizenship / residency status code (internal code set)."/>
        <FIELD NAME="usi"            TYPE="char" LENGTH="16"  NOTNULL="false"
                                     COMMENT="Unique Student Identifier. NULL = not recorded."/>
        <FIELD NAME="chessn"         TYPE="char" LENGTH="16"  NOTNULL="false"
                                     COMMENT="Commonwealth Higher Education Student Support Number. NULL = not recorded."/>
        <FIELD NAME="disability"     TYPE="char" LENGTH="32"  NOTNULL="true" DEFAULT="notstated"
                                     COMMENT="Disability status code (internal code set). Special-category data."/>
        <FIELD NAME="prioreducation" TYPE="char" LENGTH="32"  NOTNULL="true" DEFAULT="notstated"
                                     COMMENT="Highest prior educational attainment code (internal code set)."/>
        <FIELD NAME="timecreated"    TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified"   TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="usermodified"   TYPE="int"  LENGTH="10"  NOTNULL="true" DEFAULT="0"
                                     COMMENT="FK → mdl_user.id who created or last changed the record."/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"         TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_userid"       TYPE="foreign-unique" FIELDS="userid" REFTABLE="user" REFFIELDS="id" COMMENT="One higher education record per learner."/>
        <KEY NAME="fk_usermodified" TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>

  </TABLES>
</XMLDB>
